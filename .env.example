# Database
DB_URL=jdbc:sqlserver://<host>:1433;databaseName=chiptrip;encrypt=true;trustServerCertificate=true
DB_USERNAME=
DB_PASSWORD=

# JWT — must be at least 32 characters
JWT_SECRET=

# Google OAuth (chỉ dùng cho đăng nhập Google, KHÔNG dùng cho Maps)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI provider — Gemini API (native) qua lớp OpenAI-compatible, model gemini-2.5-flash.
# Lấy key tại https://aistudio.google.com/app/api-keys
# Nhiều key ngăn bởi dấu phẩy để tự xoay vòng khi một key hết hạn mức (429) hoặc bị từ chối (401/403).
# Ví dụ: AI_API_KEYS=key1,key2,key3 — vẫn chấp nhận AI_API_KEY (1 key) cho tương thích ngược.
AI_API_KEYS=
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Goong REST API — backend geocoding + autocomplete (rsapi.goong.io)
# Đăng ký tại https://account.goong.io
GOONG_API_KEY=

# Goong Map Token — frontend render map (Goong Maps JS / Leaflet tile)
GOONG_MAP_TOKEN=

# SerpApi — enrich dữ liệu địa điểm: rating, giờ mở cửa, ảnh
# Để trống nếu muốn tắt SerpApi (vẫn có lat/lng từ Goong)
# Đăng ký tại https://serpapi.com
SERPAPI_API_KEY=

# OpenWeather — dự báo thời tiết (tùy chọn, có fallback)
OPENWEATHER_API_KEY=

# PostHog — proxy số liệu analytics cho admin dashboard (server-side)
# Personal API Key (phx_...) tạo ở PostHog → Settings → Personal API Keys (scope query:read)
POSTHOG_API_HOST=https://us.posthog.com
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_KEY=

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@chiptrip.app

# Frontend URL (dùng cho email verification, reset password)
FRONTEND_URL=http://localhost:3000

# Admin seed — để trống nếu không muốn tự tạo tài khoản admin khi khởi động
ADMIN_EMAIL=
ADMIN_PASSWORD=
